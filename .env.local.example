# ── re-animator 환경변수 (M1) ──────────────────────────────────────────────
# 앱(Next)과 워커가 같은 Redis/Blob 을 본다. 실제 값은 .env.local 에.

# Upstash Redis (프로젝트 상태 저장 + 잡 큐)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob (소스 이미지 · 추출된 컷 이미지). Vercel 배포 시 자동 주입됨.
BLOB_READ_WRITE_TOKEN=

# ── 이후 마일스톤에서 추가 ─────────────────────────────────────────────────
# OPENAI_API_KEY=          # M2 캐스팅 VLM / M3 재생성
# XAI_API_KEY=             # M5 grok I2V(폴백/옵션)
# KLING_ACCESS_KEY=        # M5 Kling I2V(기본 엔진, 첫+끝 프레임 보간) — 콘솔 AccessKey
# KLING_SECRET_KEY=        # M5 Kling I2V — 콘솔 SecretKey
# KLING_VIDEO_MODEL=       # (선택) 기본 kling-v2-1. 계정에서 쓸 수 있는 모델로.
# FAL_KEY=                 # M5 대안 엔진(옵션)
# ELEVENLABS_API_KEY=      # M6 TTS
# TYPECAST_API_KEY=        # M6 TTS
